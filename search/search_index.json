\u0446\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043a\u043e\u0440\u0440\u0435\u043b\u0438\u0440\u0443\u044e\u0442 (\u22120.69) - \u044d\u0442\u043e \u043b\u043e\u0433\u0438\u0447\u043d\u043e, \u0442.\u043a. \u043e\u0434\u0438\u043d \u043f\u0440\u0438\u0437\u043d\u0430\u043a \u0432\u044b\u0447\u0438\u0441\u043b\u0435\u043d \u0438\u0437 \u0434\u0440\u0443\u0433\u043e\u0433\u043e - <code>isAlone</code> \u0443\u043c\u0435\u0440\u0435\u043d\u043d\u043e \u043e\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043a\u043e\u0440\u0440\u0435\u043b\u0438\u0440\u0443\u0435\u0442 \u0441 \u0432\u044b\u0436\u0438\u0432\u0430\u0435\u043c\u043e\u0441\u0442\u044c\u044e (\u22120.20) - \u043e\u0434\u0438\u043d\u043e\u043a\u0438\u0435 \u043f\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u044b \u0432\u044b\u0436\u0438\u0432\u0430\u043b\u0438 \u0440\u0435\u0436\u0435 - \u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u043f\u0440\u0438\u0437\u043d\u0430\u043a\u0438 (Age_group, Title, Letter) \u0438\u0441\u043a\u043b\u044e\u0447\u0435\u043d\u044b \u0438\u0437 \u043a\u043e\u0440\u0440\u0435\u043b\u044f\u0446\u0438\u043e\u043d\u043d\u043e\u0433\u043e \u0430\u043d\u0430\u043b\u0438\u0437\u0430, \u0442\u0430\u043a \u043a\u0430\u043a \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u0442 \u0442\u0435\u043a\u0441\u0442\u043e\u0432\u044b\u0435 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f</p>"},{"location":"lab6/#_19","title":"\u0417\u0430\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435","text":""},{"location":"lab6/#_20","title":"\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0440\u0430\u0431\u043e\u0442\u044b","text":"<p>\u0412 \u0445\u043e\u0434\u0435 \u043b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u044b \u0431\u044b\u043b \u043f\u0440\u043e\u0432\u0435\u0434\u0451\u043d \u043f\u043e\u043b\u043d\u044b\u0439 \u0446\u0438\u043a\u043b \u043f\u0440\u0435\u0434\u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0434\u0430\u043d\u043d\u044b\u0445:</p> <ol> <li>\u041f\u0435\u0440\u0432\u0438\u0447\u043d\u044b\u0439 \u0430\u043d\u0430\u043b\u0438\u0437 - \u0438\u0437\u0443\u0447\u0435\u043d\u044b \u0442\u0438\u043f\u044b, \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0438, \u0432\u044b\u044f\u0432\u043b\u0435\u043d\u044b \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0438 \u0432 Age (177), Cabin (687), Embarked (2)</li> <li>\u041e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u043e\u0432 - Age \u0437\u0430\u043f\u043e\u043b\u043d\u0435\u043d \u043c\u0435\u0434\u0438\u0430\u043d\u043e\u0439, Embarked - \u043c\u043e\u0434\u043e\u0439, \u0438\u0437 Cabin \u0441\u043e\u0437\u0434\u0430\u043d \u043d\u043e\u0432\u044b\u0439 \u043f\u0440\u0438\u0437\u043d\u0430\u043a Letter</li> <li>\u0422\u0440\u0430\u043d\u0441\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f - \u0441\u043e\u0437\u0434\u0430\u043d\u043e 5 \u043d\u043e\u0432\u044b\u0445 \u043f\u0440\u0438\u0437\u043d\u0430\u043a\u043e\u0432: Age_group, Letter, Title, FamilySize, isAlone; Sex \u043f\u0435\u0440\u0435\u0432\u0435\u0434\u0451\u043d \u0432 \u0447\u0438\u0441\u043b\u043e\u0432\u043e\u0439 \u0444\u043e\u0440\u043c\u0430\u0442; Pclass - \u0432 \u0441\u0442\u0440\u043e\u043a\u043e\u0432\u044b\u0439</li> <li>\u041e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0432\u044b\u0431\u0440\u043e\u0441\u043e\u0432 - \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0430 winsorization \u0434\u043b\u044f Fare \u0438 Age \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e 95-\u0433\u043e \u043f\u0435\u0440\u0446\u0435\u043d\u0442\u0438\u043b\u044f; \u0432\u044b\u044f\u0432\u043b\u0435\u043d\u043e 116 \u0432\u044b\u0431\u0440\u043e\u0441\u043e\u0432 \u0432 Fare \u043c\u0435\u0442\u043e\u0434\u043e\u043c IQR</li> <li>\u0410\u0433\u0440\u0435\u0433\u0430\u0446\u0438\u044f - \u043f\u043e\u043a\u0430\u0437\u0430\u043d\u0430 \u0441\u0432\u044f\u0437\u044c \u0432\u044b\u0436\u0438\u0432\u0430\u0435\u043c\u043e\u0441\u0442\u0438 \u0441 \u043a\u043b\u0430\u0441\u0441\u043e\u043c \u0438 \u043f\u043e\u043b\u043e\u043c; \u043d\u0430\u0439\u0434\u0435\u043d\u043e, \u0447\u0442\u043e \u043f\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u044b \u0441 \u0441\u0435\u043c\u044c\u0451\u0439 \u0432\u044b\u0436\u0438\u0432\u0430\u043b\u0438 \u0447\u0430\u0449\u0435</li> <li>\u041c\u0435\u0442\u0440\u0438\u043a\u0438 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430 - \u043f\u0440\u043e\u0446\u0435\u043d\u0442 \u0437\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u043d\u044b\u0445 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0439, \u0440\u0430\u0441\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u044f \u043d\u043e\u0432\u044b\u0445 \u043f\u0440\u0438\u0437\u043d\u0430\u043a\u043e\u0432, \u043a\u043e\u0440\u0440\u0435\u043b\u044f\u0446\u0438\u0438</li> </ol>"},{"location":"lab6/#_21","title":"\u0412\u044b\u0432\u043e\u0434\u044b","text":"<ul> <li>\u0417\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435 \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u043e\u0432 \u043c\u0435\u0434\u0438\u0430\u043d\u043e\u0439 \u0441\u0433\u043b\u0430\u0436\u0438\u0432\u0430\u0435\u0442 \u0440\u0430\u0437\u043b\u0438\u0447\u0438\u044f \u043c\u0435\u0436\u0434\u0443 \u0433\u0440\u0443\u043f\u043f\u0430\u043c\u0438 - \u043e\u0431 \u044d\u0442\u043e\u043c \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0443\u0435\u0442 \u043e\u0434\u0438\u043d\u0430\u043a\u043e\u0432\u044b\u0439 \u043c\u0435\u0434\u0438\u0430\u043d\u043d\u044b\u0439 \u0432\u043e\u0437\u0440\u0430\u0441\u0442 \u043f\u043e \u0432\u0441\u0435\u043c \u043f\u043e\u0440\u0442\u0430\u043c</li> <li>\u041f\u0435\u0440\u0432\u044b\u0439 \u043a\u043b\u0430\u0441\u0441 \u0438 \u043d\u0430\u043b\u0438\u0447\u0438\u0435 \u0441\u0435\u043c\u044c\u0438 \u0437\u043d\u0430\u0447\u0438\u043c\u043e \u0441\u0432\u044f\u0437\u0430\u043d\u044b \u0441 \u0432\u044b\u0436\u0438\u0432\u0430\u0435\u043c\u043e\u0441\u0442\u044c\u044e</li> <li>\u041f\u0440\u0438\u0437\u043d\u0430\u043a isAlone \u043e\u043a\u0430\u0437\u0430\u043b\u0441\u044f \u0443\u043c\u0435\u0440\u0435\u043d\u043d\u043e \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u0432\u043d\u044b\u043c (\u043a\u043e\u0440\u0440\u0435\u043b\u044f\u0446\u0438\u044f \u22120.20 \u0441 Survived)</li> <li>\u0411\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u043f\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u043e\u0432 (730 \u0438\u0437 891) - \u0432\u0437\u0440\u043e\u0441\u043b\u044b\u0435 (18\u201360 \u043b\u0435\u0442)</li> </ul>"},{"location":"lab7/","title":"\u041b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u0430\u044f 7","text":""},{"location":"lab7/#no7","title":"\u041b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u21167: \u0410\u043d\u0430\u043b\u0438\u0437 \u0442\u0435\u043a\u0441\u0442\u0430","text":"<p>\u0421\u0441\u044b\u043b\u043a\u0430 \u043d\u0430 ipynb-\u0431\u043e\u0440\u0434</p>"},{"location":"lab8/","title":"\u041b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u0430\u044f 8","text":""},{"location":"lab8/#no8","title":"\u041b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u21168: \u0421\u043a\u0440\u0430\u043f\u0438\u043d\u0433 \u0438 \u0430\u043d\u0430\u043b\u0438\u0437 \u0442\u0435\u043a\u0441\u0442\u0430","text":"<p>\u0421\u0441\u044b\u043b\u043a\u0430 \u043d\u0430 ipynb-\u0431\u043e\u0440\u0434</p>"},{"location":"lab9/","title":"\u041b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u0430\u044f 9","text":""},{"location":"projects/","title":"\u0412\u0432\u0435\u0434\u0435\u043d\u0438\u0435","text":""},{"location":"projects/#_1","title":"\u041c\u043e\u0438 \u041f\u0440\u043e\u0435\u043a\u0442\u044b","text":"<p>\u0417\u0434\u0435\u0441\u044c \u0441\u043e\u0431\u0440\u0430\u043d\u044b \u043c\u043e\u0438 \u043b\u0443\u0447\u04